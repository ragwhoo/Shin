# Ignore everything except Desktop/SHIN/
/*
!.gitignore
!/Desktop/
/Desktop/*
!/Desktop/SHIN/
!/Desktop/SHIN/**/

# Track EE plugin and skill (OpenCode integration)
!/.opencode/
/.opencode/*
!/.opencode/plugins/
/.opencode/plugins/*
!/.opencode/plugins/ee-experience/
!/.opencode/plugins/ee-experience/**
/.opencode/plugins/ee-experience/node_modules/
!/.agents/
/.agents/*
!/.agents/skills/
/.agents/skills/*
!/.agents/skills/engineering-experience-engine/
!/.agents/skills/engineering-experience-engine/**

# Common build artifacts inside SHIN
Desktop/SHIN/**/node_modules/
Desktop/SHIN/**/target/
Desktop/SHIN/**/.next/
Desktop/SHIN/**/__pycache__/
Desktop/SHIN/**/*.class
Desktop/SHIN/**/*.jar
Desktop/SHIN/**/*.war
Desktop/SHIN/**/.env
Desktop/SHIN/**/.env.local
Desktop/SHIN/**/.DS_Store
Desktop/SHIN/**/dist/
Desktop/SHIN/**/build/
